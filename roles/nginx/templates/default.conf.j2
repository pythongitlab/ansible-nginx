server {
    listen 80;
    server_name {{ server_name }};
    root {{ root_path }};
    index index.php index.html index.htm;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:{{ php_fpm_socket }};
    }

    location ~ /\.ht {
        deny all;
    }
}
